# LWC Utility Token — Environment Variables
# Creator: Richard Patterson (@De-ASI-INTERFACE)
# NEVER commit a populated .env to version control

# Solana RPC
RPC_URL=https://api.mainnet-beta.solana.com
RPC_URL_BACKUP=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY

# Wallet (base58 private key — use hardware wallet in production)
SOLANA_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY

# LWC Token
LWC_MINT_ADDRESS=YOUR_LWC_MINT_ADDRESS

# Treasury
UBI_TREASURY_PUBKEY=YOUR_TREASURY_WALLET_PUBKEY

# Fee config (basis points)
LWC_FEE_BPS=30
LWC_BURN_BPS=10
LWC_TREASURY_BPS=10
LWC_LP_REWARD_BPS=10

# AMM
DEFAULT_SLIPPAGE_BPS=50
MAX_PRICE_IMPACT_PCT=2.0
DRY_RUN=true

# Jupiter
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Governance
MIN_LWC_STAKE_FOR_VOTE=100
VOTING_PERIOD_SECONDS=259200

# API Subscriptions
DEASI_API_URL=https://api.deasi.io

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=YOUR_GRAFANA_API_KEY
